{
  "name": "multi-platform-reach-out",
  "version": "1.0.0",
  "description": "Desktop and ngrok outreach tool for Nationale Hulpgids campaigns.",
  "author": "Noodzakelijk Online",
  "type": "module",
  "main": "desktop/main.cjs",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development USE_VITE_DEV_SERVER=true tsx watch server/_core/index.ts",
    "build": "node scripts/build.cjs",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:local": "cross-env NODE_ENV=production LOCAL_DESKTOP_MODE=1 LOCAL_DATA_DIR=.local-data node dist/index.js",
    "start:ngrok": "cross-env NODE_ENV=production NGROK_ENABLED=true node dist/index.js",
    "installer:win": "pnpm build && cross-env ELECTRON_CACHE=.electron-cache electron_config_cache=.electron-cache ELECTRON_BUILDER_CACHE=.electron-builder-cache electron-builder --win nsis",
    "installer:win:signed": "pnpm build && cross-env ELECTRON_CACHE=.electron-cache electron_config_cache=.electron-cache ELECTRON_BUILDER_CACHE=.electron-builder-cache electron-builder --win nsis -c.win.signAndEditExecutable=true",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run --configLoader runner",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "@ngrok/ngrok": "^1.5.2",
    "@trpc/server": "^11.17.0",
    "axios": "^1.16.1",
    "cheerio": "^1.2.0",
    "cookie": "^1.0.2",
    "crawlee": "^3.15.3",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.45.2",
    "express": "^4.22.2",
    "jose": "6.1.0",
    "mysql2": "^3.15.0",
    "rate-limiter-flexible": "^9.0.1",
    "superjson": "^1.13.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@builder.io/vite-plugin-jsx-loc": "^0.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.7",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.90.2",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@types/express": "4.17.21",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "add": "^2.0.6",
    "autoprefixer": "^10.4.20",
    "bullmq": "^5.77.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cross-env": "^7.0.3",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.4",
    "embla-carousel-react": "^8.6.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "framer-motion": "^12.23.22",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.453.0",
    "nanoid": "^5.1.5",
    "next-themes": "^0.4.6",
    "playwright": "^1.58.1",
    "pnpm": "^10.33.4",
    "postcss": "^8.5.15",
    "prettier": "^3.6.2",
    "react": "^19.2.1",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.64.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^2.15.2",
    "sonner": "^2.0.7",
    "streamdown": "^1.6.11",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3",
    "vaul": "^1.1.2",
    "vite": "^7.3.3",
    "vite-plugin-manus-runtime": "^0.0.57",
    "vitest": "^4.1.7",
    "wouter": "^3.3.5"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "electron-winstaller"
    ],
    "patchedDependencies": {
      "wouter@3.7.1": "patches/wouter@3.7.1.patch"
    },
    "overrides": {
      "tailwindcss>nanoid": "3.3.7",
      "dompurify": "3.4.5",
      "esbuild": "0.25.10",
      "file-type": "21.3.2",
      "ip-address": "10.2.0",
      "lodash": "4.18.1",
      "lodash-es": "4.18.1",
      "mdast-util-to-hast": "13.2.1",
      "mermaid": "11.15.0",
      "minimatch": "9.0.9",
      "path-to-regexp": "0.1.13",
      "picomatch": "4.0.4",
      "rollup": "4.60.4",
      "tar": "7.5.15",
      "undici": "7.25.0",
      "uuid": "11.1.1",
      "ws": "8.21.0"
    }
  },
  "build": {
    "appId": "nl.noodzakelijkonline.reachout",
    "productName": "Nationale Hulpgids Reach-Out",
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "desktop/icon.ico",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "icon": "desktop/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "desktop/icon.ico",
      "uninstallerIcon": "desktop/icon.ico",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
